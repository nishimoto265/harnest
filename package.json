{
  "name": "@delish/auto-improve",
  "version": "0.1.0",
  "private": true,
  "description": "Self-improving harness pipeline (rules + scoring + promotion) — M1 skeleton",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.7.0",
  "bin": {
    "auto-improve": "src/bin/auto-improve.ts"
  },
  "scripts": {
    "auto-improve": "tsx src/bin/auto-improve.ts",
    "preflight": "tsx src/bin/auto-improve.ts preflight",
    "detect-merged": "tsx src/bin/auto-improve.ts detect-merged",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "js-yaml": "^4.1.0",
    "pino": "^9.5.0",
    "pino-pretty": "^11.2.2",
    "tsx": "^4.19.2",
    "zod": "^3.23.8",
    "zx": "^8.2.4"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.0.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
