# Copy to config.yaml and edit for your environment.

repo:
  github: "owner/repo" # Required for detect-merged and detect-loop.
  root: "/abs/path/to/auto-improve" # Repository root for manual CLI use and launchd.
  default_branch: "main" # Branch watched by detect-merged and detect-loop.
  best_branch: "auto-improve/best" # Promotion target branch.
  policy_branch: "auto-improve/policy" # Optional; repo-backed learned policy branch.
paths:
  runs: "/abs/path/to/auto-improve-state/runs" # Durable absolute directory for per-run artifacts.
worktree:
  base: "/abs/path/to/auto-improve-state/worktrees" # Durable absolute directory for git worktrees.
task_prompt:
  source: "auto" # auto | issue | pr | diff_synth
agent_config_path: "./agents.yaml" # Optional; defaults to ./agents.yaml when present, otherwise legacy role defaults.
claude_cli_path: "claude" # Absolute path, or bare command name found in the trusted runtime PATH.
codex_cli_path: "codex" # Absolute path, or bare command name found in the trusted runtime PATH.
preflight_timeout_sec: 30 # Timeout for preflight checks in seconds.
rescue_max_retries: 3 # Max worktree rescue attempts before manual recovery.
registry_high_threshold: 1501 # Warn when the registry line count exceeds this value.
registry_critical_threshold: 2001 # Escalate when the registry line count exceeds this value.
step_timeouts: # Per-step timeout budget in seconds.
  step10: 300 # Restore base and allocate worktrees.
  step20: 1800 # Pass 1 implementation.
  step30: 1800 # Pass 1 scoring.
  step40: 900 # Candidate rule extraction.
  step50: 1800 # Pass 2 implementation.
  step60: 1800 # Pass 2 scoring.
  step70: 300 # Promotion and registry update.
