# Copy to agents.yaml and edit for your runtime.

profiles:
  claude:
    provider: claude
    binary: claude
    # Optional: use when the Claude wrapper is a Node shebang script that must
    # run with a specific Node version.
    # node_binary: /absolute/path/to/node
    args: ["-p"]
  codex:
    provider: codex
    binary: codex
  stub:
    provider: stub

roles:
  implementer: claude
  judge_primary: stub
  judge_secondary: stub
  judge_arbiter: stub
  # Optional: enable AI task brief generation. Omit to use deterministic fallback.
  # task_generator: codex
