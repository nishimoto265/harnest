#!/bin/sh
set -eu

if [ "${1:-}" = "-C" ]; then
  repo_dir="$2"
  shift 2
else
  repo_dir="$(pwd)"
fi

subcmd="$1"
shift

case "$subcmd" in
  rev-parse)
    if [ "${1:-}" = "--verify" ]; then
      echo "${AUTO_IMPROVE_TEST_BEST_SHA}"
      exit 0
    fi
    case "${1:-}" in
      *^1)
        echo "${AUTO_IMPROVE_TEST_BASE_SHA}"
        ;;
      HEAD)
        echo "${AUTO_IMPROVE_TEST_TARGET_SHA}"
        ;;
      *)
        echo "${AUTO_IMPROVE_TEST_BEST_SHA}"
        ;;
    esac
    ;;
  worktree)
    case "${1:-}" in
      add)
        if [ "${2:-}" = "-b" ]; then
          path="$4"
        else
          path="$2"
        fi
        mkdir -p "$path"
        ;;
      remove)
        rm -rf "$3"
        ;;
      *)
        echo "unsupported worktree args: $*" >&2
        exit 1
        ;;
    esac
    ;;
  diff)
    exit 0
    ;;
  ls-files)
    exit 0
    ;;
  status)
    exit 0
    ;;
  branch)
    echo "stub-branch"
    ;;
  ls-remote)
    branch="${4:-best}"
    printf '%s\trefs/heads/%s\n' "${AUTO_IMPROVE_TEST_BEST_SHA}" "$branch"
    ;;
  push)
    exit 0
    ;;
  *)
    echo "unsupported git subcommand: $subcmd $*" >&2
    exit 1
    ;;
esac

exit 0
