#!/bin/sh
set -eu

if [ "$1" = "pr" ] && [ "$2" = "view" ]; then
  pr="${3}"
  cat <<EOF
{"number":${pr},"title":"Stub PR ${pr}","body":"Stub body","state":"MERGED","baseRefOid":"${AUTO_IMPROVE_TEST_BASE_SHA}","headRefOid":"${AUTO_IMPROVE_TEST_TARGET_SHA}","mergeCommit":{"oid":"${AUTO_IMPROVE_TEST_MERGE_SHA}"},"potentialMergeCommit":{"oid":"${AUTO_IMPROVE_TEST_MERGE_SHA}"},"closingIssuesReferences":[]}
EOF
  exit 0
fi

if [ "$1" = "issue" ] && [ "$2" = "view" ]; then
  issue="${3}"
  cat <<EOF
{"number":${issue},"title":"Stub issue ${issue}","body":"Stub issue body"}
EOF
  exit 0
fi

echo "unsupported gh args: $*" >&2
exit 1
